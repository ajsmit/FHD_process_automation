# =============================================================================
# PG Workflow Platform — Environment Variables Reference
# =============================================================================
# AUTHORITATIVE TEMPLATE: this file is the single source of truth for all env vars.
# Compatibility projection files:
# - server/.env.example  (server subset)
# - client/.env.example  (client subset)
# Update this file first, then sync projection files in the same change.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER (server/.env)
# -----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Bootstrapping
# Local dev: true/true. Production: false/false unless intentionally bootstrapping.
AUTO_INIT_DB=true
ENABLE_DEMO_DATA=true
ENABLE_DEV_AUTH=true
ENABLE_LEGACY_PHASE1=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# sqlite3 (local) or mysql2 (server)
DB_CLIENT=sqlite3
SQLITE_FILE=./dev.sqlite3

# MySQL (used when DB_CLIENT=mysql2)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=fhd_process_automation
# Optional full connection string (takes precedence over host/user/pass):
# DATABASE_URL=mysql://root:change_me@127.0.0.1:3306/fhd_process_automation

# SASI provider
# local = read mock/local sasi_students table
# api   = read remote SASI API
SASI_PROVIDER=local
SASI_API_ENDPOINT=
SASI_API_KEY=

# External academic invite links
# Set to the public client URL so invite emails carry a resolvable link.
EXTERNAL_PROFILE_BASE_URL=http://localhost:3000
# 32-byte base64 or 64-char hex key for encrypting external invite tokens at rest.
# Required in production; dev fallback exists for local development only.
EXTERNAL_INVITE_TOKEN_ENCRYPTION_KEY=

# SMTP (required for automatic invite email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional pool tuning (mysql only)
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT (used for transition endpoint auth)
JWT_SECRET=
JWT_EXPIRES_IN=
REFRESH_TOKEN_TTL_DAYS=14
AUTH_PROVIDER=local_password
# For AUTH_PROVIDER=trusted_header:
# AUTH_PROVIDER_SECRET_HEADER=x-auth-provider-secret
# AUTH_PROVIDER_SHARED_SECRET=change_me
# AUTH_PROVIDER_EMAIL_HEADER=x-auth-user-email
# AUTH_PROVIDER_SASI_ID_HEADER=x-auth-user-sasi-id
# AUTH_PROVIDER_STAFF_NUMBER_HEADER=x-auth-user-staff-number
# AUTH_PROVIDER_TRUSTED_PROXY_IPS=127.0.0.1,::1

# Demo credential for seeded users (for /auth/login in local development)
DEMO_USER_PASSWORD=ChangeMe123!

# Auth endpoint rate limits (dev-login and future auth entrypoints)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# -----------------------------------------------------------------------------
# CLIENT (client/.env.local)
# -----------------------------------------------------------------------------

# Base URL for all browser-side API calls.
# Must point to the running server origin + /api/v1.
# Local:
NEXT_PUBLIC_API_BASE=http://localhost:3001/api/v1
# Production example:
# NEXT_PUBLIC_API_BASE=https://your-api-domain.example/api/v1
