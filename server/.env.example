# This file is a server-only projection of the authoritative root template:
#   /.env.example
# Update /.env.example first, then keep this file synchronized.

# Runtime
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Bootstrapping
# Local dev: true/true. Production: false/false unless intentionally bootstrapping.
AUTO_INIT_DB=true
ENABLE_DEMO_DATA=true
ENABLE_DEV_AUTH=true
ENABLE_LEGACY_PHASE1=false
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
# sqlite3 (local) or mysql2 (server)
DB_CLIENT=sqlite3
SQLITE_FILE=./dev.sqlite3

# MySQL (used when DB_CLIENT=mysql2)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=fhd_process_automation
# Optional full connection string (takes precedence over host/user/pass):
# DATABASE_URL=mysql://root:change_me@127.0.0.1:3306/fhd_process_automation

# SASI provider
# local = read mock/local sasi_students table
# api = read remote SASI API
SASI_PROVIDER=local
SASI_API_ENDPOINT=
SASI_API_KEY=

# External academic invite links
EXTERNAL_PROFILE_BASE_URL=http://localhost:3000

# SMTP (required for automatic invite email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional pool tuning (mysql)
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT (used for transition endpoint auth)
JWT_SECRET=
JWT_EXPIRES_IN=
REFRESH_TOKEN_TTL_DAYS=14

# Demo credential for seeded users (for /auth/login in local development)
DEMO_USER_PASSWORD=ChangeMe123!

# Auth endpoint rate limits (dev-login and future auth entrypoints)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
