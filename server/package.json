{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "description": "Backend API for FHD Process Automation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/runMigrations.ts",
    "openapi:generate": "tsx src/contracts/generateOpenApi.ts"
  },
  "dependencies": {
    "@fhd/common-types": "1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.18.2",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "sqlite3": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.8",
    "@types/nodemailer": "^6.4.23",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.6"
  }
}
